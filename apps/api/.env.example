NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# اختياري: مفتاح Bearer لـ GET/PUT /v1/admin/home (8 أحرف على الأقل). بدون المفتاح تُعطل مسارات الإدارة.
ADMIN_API_KEY=

# اختياري: مسار ملف سجل رسائل التواصل (افتراضي: data/contact-inbox.jsonl داخل المستودع)
# CONTACT_INBOX_PATH=

# اختياري: مسار ملف الصفحة الرئيسية JSON (للنشر مع قرص دائم مثل Render — انسخ الملف مرة من المستودع)
# HOME_PAGE_JSON_PATH=/data/home.v1.json

# اختياري: مجلد رفع الصور/الفيديو من لوحة الإدارة (على Render مع قرص: /data/uploads)
# MEDIA_UPLOAD_DIR=/data/uploads

# اختياري — Resend: إشعار بريد عند إرسال نموذج التواصل (بعد حفظ السجل في الملف)
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=Dar Car <noreply@your-verified-domain.com>
# CONTACT_NOTIFY_TO=you@example.com,team@example.com
