NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000

# عنوان الـ API من خادم Next (مسارات /api/*). محلياً غالباً نفس NEXT_PUBLIC_API_URL
API_INTERNAL_URL=http://127.0.0.1:4000

# true = جلب الصفحة الرئيسية من GET /v1/content/home أثناء البناء/التشغيل
# اتركه معطّلاً (أو احذفه) لتجنب ECONNREFUSED عند next build بدون تشغيل الـ API
NEXT_PUBLIC_USE_HOME_API=

# روابط المتاجر (استبدل المعرفات عند نشر التطبيق الحقيقي)
NEXT_PUBLIC_IOS_APP_STORE_URL=
NEXT_PUBLIC_GOOGLE_PLAY_URL=

# لوحة التحرير في /admin — يجب أن يطابق ADMIN_API_KEY في تطبيق الـ API
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
ADMIN_API_KEY=
